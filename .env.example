# Zugangsdaten nicht in Dateien speichern – Windows-Benutzerumgebungsvariablen nutzen.
# Einrichtung: npm run setup:db -- DEIN_POSTGRES_PASSWORT
#
# Gesetzte Variablen:
#   DATABASE_URL=postgresql://postgres:...@localhost:5432/bewerbungen
#   JWT_SECRET=<automatisch generiert>
#   PORT=3001
#
# Anzeigen (PowerShell):
#   [Environment]::GetEnvironmentVariable('DATABASE_URL', 'User')
